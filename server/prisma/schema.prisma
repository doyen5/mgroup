generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
  FORCE_PASSWORD_CHANGE
}

enum RoleName {
  ADMIN
  SECRETAIRE
  COMPTABLE
  RH
  COMMERCIAL
  CLIENT
  AUTRE
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  PHONE_OTP_SENT
  PHONE_LOGIN_SUCCESS
  GOOGLE_LOGIN_SUCCESS
  TWO_FACTOR_CHALLENGE
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  ACCOUNT_LOCKED
  USER_REGISTERED
  USER_APPROVED
  USER_DISABLED
  USER_REACTIVATED
  USER_PASSWORD_RESET
  ROLE_CHANGED
  PROFILE_UPDATED
  COMPANY_UPDATED
  SETUP_COMPLETED
}

enum AuthChallengeType {
  LOGIN_2FA
  PHONE_LOGIN
}

enum EventStatus {
  DRAFT
  IN_PREPARATION
  VALIDATED
  COMPLETED
  CANCELLED
}

enum EventAttachmentType {
  CONTRACT
  TECHNICAL_SHEET
  QUOTE
  PHOTO
  OTHER
}

enum BudgetStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum FinanceDocumentType {
  QUOTE
  INVOICE
  RECEIPT
  OTHER
}

model Company {
  id             String   @id @default(cuid())
  name           String
  legalName      String
  address        String
  email          String
  phone          String
  photoUrl       String?
  taxInfo        String?
  documentFooter String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users  User[]
  events Event[]
}

model User {
  id                    String     @id @default(cuid())
  companyId             String?
  firstName             String
  lastName              String
  address               String?
  email                 String     @unique
  phone                 String?
  photoUrl              String?
  passwordHash          String?
  status                UserStatus @default(PENDING)
  lastLoginAt           DateTime?
  emailVerifiedAt       DateTime?
  phoneVerifiedAt       DateTime?
  failedLoginAttempts   Int        @default(0)
  lockedUntil           DateTime?
  twoFactorEnabled      Boolean    @default(false)
  twoFactorSecret       String?
  lastPasswordChangedAt DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  company                 Company?                 @relation(fields: [companyId], references: [id], onDelete: SetNull)
  roles                   UserRole[]
  refreshTokens           RefreshToken[]
  resetTokens             PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  authChallenges          AuthChallenge[]
  oauthAccounts           OAuthAccount[]
  auditLogs               LoginAuditLog[]
  createdEvents           Event[]                  @relation("EventCreatedBy")
  responsibleEvents       Event[]                  @relation("EventResponsible")
  eventAssignments        EventAssignment[]
  productionSteps         EventProductionStep[]    @relation("EventProductionOwner")
  validatedBudgets        EventBudget[]            @relation("EventBudgetValidator")
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  label       String
  description String?
  createdAt   DateTime @default(now())

  users UserRole[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  lastUsedAt DateTime?
  rememberMe Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthChallenge {
  id        String            @id @default(cuid())
  userId    String
  type      AuthChallengeType
  tokenHash String?
  expiresAt DateTime
  usedAt    DateTime?
  metadata  Json?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model LoginAuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Event {
  id            String      @id @default(cuid())
  companyId     String?
  title         String
  description   String?
  location      String?
  startsAt      DateTime
  endsAt        DateTime?
  budgetFcfa    Int?
  status        EventStatus @default(DRAFT)
  createdById   String?
  responsibleId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company     Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdBy   User?                  @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  responsible User?                  @relation("EventResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  assignments EventAssignment[]
  checklist   EventChecklistItem[]
  steps       EventProductionStep[]
  attachments EventAttachment[]
  budgets     EventBudget[]
  expenses    EventExpense[]
  payments    EventPayment[]
  documents   EventFinanceDocument[]
}

model EventAssignment {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  roleNote  String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventChecklistItem {
  id        String    @id @default(cuid())
  eventId   String
  title     String
  isDone    Boolean   @default(false)
  dueAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventProductionStep {
  id        String      @id @default(cuid())
  eventId   String
  title     String
  notes     String?
  startsAt  DateTime?
  endsAt    DateTime?
  status    EventStatus @default(IN_PREPARATION)
  ownerId   String?
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner User? @relation("EventProductionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}

model EventAttachment {
  id        String              @id @default(cuid())
  eventId   String
  type      EventAttachmentType @default(OTHER)
  label     String
  url       String
  fileName  String?
  mimeType  String?
  createdAt DateTime            @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventBudget {
  id                 String       @id @default(cuid())
  eventId            String
  label              String
  plannedAmountFcfa  Int
  approvedAmountFcfa Int?
  status             BudgetStatus @default(DRAFT)
  notes              String?
  validatedById      String?
  validatedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  event       Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  validatedBy User? @relation("EventBudgetValidator", fields: [validatedById], references: [id], onDelete: SetNull)
}

model EventExpense {
  id         String   @id @default(cuid())
  eventId    String
  label      String
  category   String?
  vendor     String?
  amountFcfa Int
  spentAt    DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventPayment {
  id         String        @id @default(cuid())
  eventId    String
  label      String
  amountFcfa Int
  status     PaymentStatus @default(PENDING)
  dueAt      DateTime?
  paidAt     DateTime?
  method     String?
  reference  String?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventFinanceDocument {
  id         String              @id @default(cuid())
  eventId    String
  type       FinanceDocumentType @default(OTHER)
  label      String
  amountFcfa Int?
  url        String
  fileName   String?
  mimeType   String?
  createdAt  DateTime            @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
